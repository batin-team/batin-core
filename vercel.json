{
  "version": 2,
  "framework": null,
  "cleanUrls": true,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && cd client && npm install && npm run build",
  "outputDirectory": "client/out",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/dashboard/client/((?!profile|dummy|.*\\.js|.*\\.css).*)" ,
      "destination": "/dashboard/client/dummy"
    },
    {
      "source": "/psychologists/((?!dummy|.*\\.js|.*\\.css).*)" ,
      "destination": "/psychologists/dummy"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}